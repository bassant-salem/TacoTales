@model OrderViewModel
@{
    ViewBag.Title = "Create Order";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">🌮 Our Menu</h1>

 
    @if (Model.OrderItems != null && Model.OrderItems.Any())
    {
        <a asp-action="Cart" class="btn btn-primary position-relative">
            🛒 Create Order
            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                @Model.OrderItems.Sum(i => i.Quantity)
            </span>
        </a>
    }
    else
    {
        <a asp-action="Cart" class="btn btn-outline-secondary disabled" aria-disabled="true">
            🛒 Create Order
        </a>
    }
</div>


<div class="row g-4">
    @foreach (Product product in Model.Products)
    {
        var inCart = Model.OrderItems?
        .FirstOrDefault(i => i.ProductId == product.ProductId)
        ?.Quantity ?? 0;

        <div class="col-md-4">
            <form asp-action="AddItem" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="prodId" value="@product.ProductId" />

                <div class="card h-100 shadow-sm">
                    <img src="@Url.Action("GetImage", "Product", new { id = product.ProductId })"
                         class="card-img-top"
                         style="height:200px; object-fit:cover;"
                         alt="@product.Name" />

                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@product.Name</h5>
                        <p class="card-text text-muted small">@product.Description</p>

                        <div class="mt-auto">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="fw-bold text-primary fs-5">
                                    @product.Price.ToString("C")
                                </span>
                                <div class="d-flex gap-1 flex-wrap justify-content-end">
                                    @if (inCart > 0)
                                    {
                                        <span class="badge bg-success">@inCart in cart</span>
                                    }
                                    @if (product.Stock <= 0)
                                    {
                                        <span class="badge bg-danger">Out of Stock</span>
                                    }
                                    else if (product.Stock <= 5)
                                    {
                                        <span class="badge bg-warning text-dark">Only @product.Stock left!</span>
                                    }
                                </div>
                            </div>

                            <div class="input-group">
                                <input type="number"
                                       name="prodQty"
                                       value="1"
                                       min="1"
                                       max="@(product.Stock > 0 ? Math.Min(product.Stock, 99) : 1)"
                                       class="form-control"
                                       aria-label="Quantity for @product.Name"
                                       @(product.Stock <= 0 ? "disabled" : "") />
                                <button class="btn btn-info text-white"
                                        type="submit"
                                        @(product.Stock <= 0 ? "disabled" : "")>
                                    @(product.Stock <= 0 ? "Out of Stock" : "Add to Cart")
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    }
</div>

@if (Model.OrderItems != null && Model.OrderItems.Any())
{
    <div class="fixed-bottom bg-white border-top shadow p-3 d-flex justify-content-between align-items-center">
        <span class="fw-semibold">
            @Model.OrderItems.Sum(i => i.Quantity) item(s) —
            <span class="text-primary">@Model.TotalAmount.ToString("C")</span>
        </span>
        <a asp-action="Cart" class="btn btn-primary">
            Create Order →
        </a>
    </div>

    <div style="height:80px"></div>
}
