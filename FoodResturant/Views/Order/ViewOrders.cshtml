@model IEnumerable<Order>
@{
    ViewData["Title"] = "My Orders";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">📋 My Orders</h1>
    <a asp-controller="Order" asp-action="Create" class="btn btn-primary">
        🌮 New Order
    </a>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <p class="text-muted fs-5">You haven't placed any orders yet.</p>
        <a asp-controller="Order" asp-action="Create" class="btn btn-primary btn-lg mt-2">
            🌮 Order Now
        </a>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var order in Model.OrderByDescending(o => o.OrderDate))
        {
            <div class="col-12">
                <div class="card shadow-sm border-0
                                    @(order.Status == OrderStatus.Cancelled ? "opacity-75" : "")">

                    <div class="card-header d-flex justify-content-between align-items-center
                                        bg-white border-bottom">
                        <div>
                            <span class="fw-bold me-2">Order #@order.OrderId</span>
                            <small class="text-muted">
                                @order.OrderDate.ToString("MMM dd, yyyy — hh:mm tt")
                            </small>
                        </div>
                        <span class="badge bg-@order.StatusBadgeClass() fs-6">
                            @order.StatusLabel()
                        </span>
                    </div>

                    <div class="card-body">

                        @* ── Status stepper ── *@
                        <div class="d-flex align-items-center mb-3 gap-0">
                            @{
                                var steps = new[]
                                {
                                        OrderStatus.Pending,
                                        OrderStatus.Preparing,
                                        OrderStatus.Ready,
                                        OrderStatus.Delivered
                                        };
                            }

                            @if (order.Status == OrderStatus.Cancelled)
                            {
                                <div class="text-danger fw-semibold small">
                                    ❌ This order was cancelled.
                                </div>
                            }
                            else
                            {
                                @for (int i = 0; i < steps.Length; i++)
                                {
                                    var step = steps[i];
                                    var isPast = order.Status > step;
                                    var isCurrent = order.Status == step;
                                    var isFuture = order.Status < step;

                                    <div class="d-flex align-items-center flex-grow-1">
                                        @* Step circle *@
                                        <div class="d-flex flex-column align-items-center"
                                             style="min-width:70px">
                                            <div class="rounded-circle d-flex align-items-center
                                                                        justify-content-center fw-bold"
                                                 style="width:36px; height:36px; font-size:13px;
                                                                        background:@(isFuture ? "#e9ecef" : (isCurrent ? "#0d6efd" : "#198754"));
                                                                        color:@(isFuture ? "#adb5bd" : "white");
                                                                        border: 2px solid @(isCurrent ? "#0d6efd" : (isPast ? "#198754" : "#dee2e6"));
                                                                        box-shadow: @(isCurrent ? "0 0 0 4px rgba(13,110,253,0.2)" : "none")">
                                                @if (isPast)
                                                {
                                                    <span>✓</span>
                                                }
                                                else
                                                {
                                                    <span>@(i + 1)</span>
                                                }
                                            </div>
                                            <small class="mt-1 text-center"
                                                   style="font-size:11px;
                                                                          color:@(isFuture ? "#adb5bd" : (isCurrent ? "#0d6efd" : "#198754"));
                                                                          font-weight:@(isCurrent ? "700" : "400")">
                                                @step
                                            </small>
                                        </div>

                                        @* Connector line between steps *@
                                        @if (i < steps.Length - 1)
                                        {
                                            <div class="flex-grow-1 mx-1"
                                                 style="height:2px;
                                                                            background:@(order.Status > step ? "#198754" : "#dee2e6")">
                                            </div>
                                        }
                                    </div>
                                }
                            }
                        </div>

                        @* ── Order items summary ── *@
                        <div class="d-flex flex-wrap gap-2 mb-2">
                            @foreach (var item in order.OrderItems)
                            {
                                <span class="badge bg-light text-dark border">
                                    @item.Quantity× @(item.Product?.Name ?? $"Item #{item.ProductId}")
                                </span>
                            }
                        </div>

                    </div>

                    <div class="card-footer bg-white d-flex justify-content-between align-items-center">
                        <span class="fw-bold text-primary">
                            @order.TotalAmount.ToString("C")
                        </span>
                        <div class="d-flex gap-2">
                            <a asp-controller="Order"
                               asp-action="OrderDetails"
                               asp-route-id="@order.OrderId"
                               class="btn btn-sm btn-outline-secondary">
                                View Details
                            </a>
                            @if (order.Status == OrderStatus.Delivered)
                            {
                                <a asp-controller="Order" asp-action="Create"
                                   class="btn btn-sm btn-primary">
                                    🌮 Order Again
                                </a>
                            }
                        </div>
                    </div>

                </div>
            </div>
        }
    </div>
}
